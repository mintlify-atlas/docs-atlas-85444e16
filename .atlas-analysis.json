  "keyFeatures": [
    "100+ geospatial and benchmark datasets with automatic download",
    "Pre-trained models with multispectral support (Sentinel-2, Landsat, etc.)",
    "Geospatial samplers for coordinate-based sampling",
    "Lightning trainers for classification, segmentation, detection, and self-supervised learning",
    "Kornia-based transforms for geospatial data augmentation",
    "Reproducible datamodules with standardized train-val-test splits"
  ],
